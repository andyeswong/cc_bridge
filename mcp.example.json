{
  "_comment": "Copy this file to mcp.json or another local-only path and point MCP_CONFIG_PATH to it. Never commit real credentials.",
  "mcpServers": {
    "example-stdio-server": {
      "command": "npx",
      "args": ["-y", "some-mcp-server"],
      "env": {
        "API_KEY": "REPLACE_ME"
      }
    },
    "example-http-server": {
      "type": "http",
      "url": "https://mcp.example.com",
      "headers": {
        "Authorization": "Bearer REPLACE_ME"
      }
    }
  }
}
