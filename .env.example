# ─────────────────────────────────────────────
# cc_bridge server
# ─────────────────────────────────────────────

# Recommended for local-only usage.
# Use 0.0.0.0 only if you know what you are doing.
HOST=127.0.0.1

# HTTP server port
PORT=8080


# ─────────────────────────────────────────────
# Local auth
# ─────────────────────────────────────────────

# Optional.
# If empty, no Authorization header is required.
# If set, requests must include:
# Authorization: Bearer your-local-secret
CC_BRIDGE_AUTH_KEY=


# ─────────────────────────────────────────────
# Claude Code CLI
# ─────────────────────────────────────────────

# Optional.
# If empty, cc_bridge will search for "claude" in PATH.
CLAUDE_BIN=

# Optional.
# Directory where Claude Code will run.
# Example Windows:
# CLAUDE_WORKDIR=C:\Users\your-user\Development\my-project
#
# Example Linux/Mac:
# CLAUDE_WORKDIR=/home/your-user/projects/my-project
CLAUDE_WORKDIR=

# Default model when request.model is empty.
CLAUDE_DEFAULT_MODEL=claude-code

# Dangerous.
# Only enable if you fully trust local requests.
CLAUDE_SKIP_PERMS=false


# ─────────────────────────────────────────────
# Ollama
# ─────────────────────────────────────────────

# Local Ollama server.
OLLAMA_URL=http://localhost:11434


# ─────────────────────────────────────────────
# SQLite / Gorm
# ─────────────────────────────────────────────

# Usage tracking database.
USAGE_DB_PATH=./usage.db

# ─────────────────────────────────────────────
# MCP / Claude Code tools
# ─────────────────────────────────────────────

# Optional.
# Path to a local MCP registry file.
# Example:
# MCP_CONFIG_PATH=./mcp.json
MCP_CONFIG_PATH=

# Optional.
# If true, claude-bridge will load the whole MCP registry on every Claude request.
MCP_ALWAYS=false